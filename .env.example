# ── Required: LLM Provider API Keys ─────────────────────────────────────────
# Add at least one. The gateway will route to whichever providers have keys set.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── Required: Infrastructure ─────────────────────────────────────────────────
DATABASE_URL=postgres://llm0:llm0_password@localhost:5432/llm0_gateway?sslmode=disable
REDIS_URL=redis://localhost:6379

# ── Optional: Server ─────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=local   # local | production

# ── Optional: Semantic Cache ──────────────────────────────────────────────────
# When using docker compose, this is set automatically to http://embedding:8080.
# For local Go runs (without Docker), start embedding_service/ separately and set:
EMBEDDING_SERVICE_URL=http://localhost:8001

# ── Optional: Ollama (local models) ──────────────────────────────────────────
# Set OLLAMA_BASE_URL to enable local model support.
# If running Ollama on the same machine: http://host.docker.internal:11434/v1
# If running natively (no Docker):       http://localhost:11434/v1
OLLAMA_BASE_URL=

# Tier-to-model mapping — which Ollama model to use per quality tier.
# "flagship" = gpt-4o class, "balanced" = gpt-4o-mini class, "budget" = cheap/fast
OLLAMA_MODEL_FLAGSHIP=llama3.3:70b
OLLAMA_MODEL_BALANCED=qwen2.5:14b
OLLAMA_MODEL_BUDGET=gemma3:4b

# ── Optional: Failover mode ───────────────────────────────────────────────────
# Controls how cloud and local (Ollama) providers are ordered in the failover chain.
#   cloud_first  — try cloud first, fall back to Ollama   (default)
#   local_first  — try Ollama first, fall back to cloud
#   local_only   — only use Ollama, never call cloud APIs
#   cloud_only   — only use cloud providers (Ollama ignored even if configured)
FAILOVER_MODE=cloud_first

# ── Optional: Cache TTL ───────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600   # 1 hour default
